        <mxCell id="e3" value="Fetches weather forecasts&lt;br&gt;[HTTPS / JSON]" style="endArrow=blockThin;html=1;rounded=0;fontSize=11;startSize=14;endSize=14;strokeColor=#707070;fillColor=#707070;endFill=1;" edge="1" parent="1" source="app" target="met">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e4" value="Downloads env fields&lt;br&gt;[copernicusmarine SDK / NetCDF]" style="endArrow=blockThin;html=1;rounded=0;fontSize=11;startSize=14;endSize=14;strokeColor=#707070;fillColor=#707070;endFill=1;" edge="1" parent="1" source="app" target="coper">
