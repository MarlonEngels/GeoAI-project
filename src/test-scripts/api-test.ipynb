   "metadata": {},
   "outputs": [],
   "source": [
    "import requests\n",
    "\n",
    "AIS_URL = \"https://kystdatahuset.no/ws/api/ais/realtime/geojson\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "7c8ced8a",
   "metadata": {},
   "outputs": [],
   "source": [
    "def fetch_ais_geojson(timeout=10):\n",
    "    resp = requests.get(AIS_URL, timeout=timeout)\n",
    "    resp.raise_for_status()\n",
    "    return resp.json()"
   ]
  },
